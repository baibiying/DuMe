{
    "framework": "nextjs",
    "buildCommand": "bun scripts/vercel-build.mjs",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors https: http:"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/notifications/cron/daily-digest",
            "schedule": "0 17 * * *"
        }
    ]
}